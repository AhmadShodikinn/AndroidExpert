<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_item_anime"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvEpisodeNumber"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_episode_number"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="11" />

    <TextView
        android:id="@+id/tvEpisodeName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#111111"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvEpisodeDate"
        app:layout_constraintStart_toEndOf="@id/tvEpisodeNumber"
        app:layout_constraintTop_toTopOf="@id/tvEpisodeNumber"
        tools:text="Kimetsu no Yaiba: Katanakaji no Sato-hen Episode 11 Subtitle Indonesia" />

    <TextView
        android:id="@+id/tvEpisodeDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#777777"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvEpisodeName"
        tools:text="25 Juni,2023" />

    <TextView
        android:id="@+id/tvEpisodeId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#777777"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvEpisodeNumber"
        app:layout_constraintTop_toBottomOf="@id/tvEpisodeName"
        tools:text="kny-ksh-episode-11-sub-indo" />

</androidx.constraintlayout.widget.ConstraintLayout>