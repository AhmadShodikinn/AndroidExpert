<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_schedule"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <ImageButton
        android:id="@+id/btnBackSchedule"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:src="@drawable/arrow_back_24px"
        app:tint="#111111"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvScheduleTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="20dp"
        android:text="Schedule"
        android:textColor="#111111"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBackSchedule"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBackSchedule"
        app:layout_constraintTop_toTopOf="@id/btnBackSchedule" />

    <TextView
        android:id="@+id/tvScheduleSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        android:text="Jadwal rilis anime mingguan"
        android:textColor="#777777"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBackSchedule" />

    <HorizontalScrollView
        android:id="@+id/scrollDayFilter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvScheduleSubtitle">

        <LinearLayout
            android:id="@+id/layoutDayFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/tvDayAll"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_selected"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Semua"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDayMonday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Senin"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDayTuesday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Selasa"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDayWednesday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Rabu"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDayThursday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Kamis"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDayFriday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Jumat"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDaySaturday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Sabtu"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDaySunday"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Minggu"
                android:textColor="#555555"
                android:textSize="14sp" />

        </LinearLayout>

    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvScheduleSectionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="20dp"
        android:text="Semua Jadwal"
        android:textColor="#111111"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scrollDayFilter" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvScheduleAnime"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvScheduleSectionTitle"
        tools:listitem="@layout/home_item_anime" />

    <ProgressBar
        android:id="@+id/progressBarSchedule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rvScheduleAnime"
        app:layout_constraintEnd_toEndOf="@id/rvScheduleAnime"
        app:layout_constraintStart_toStartOf="@id/rvScheduleAnime"
        app:layout_constraintTop_toTopOf="@id/rvScheduleAnime"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvEmptySchedule"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:text="Jadwal anime belum tersedia"
        android:textColor="#777777"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rvScheduleAnime"
        app:layout_constraintEnd_toEndOf="@id/rvScheduleAnime"
        app:layout_constraintStart_toStartOf="@id/rvScheduleAnime"
        app:layout_constraintTop_toTopOf="@id/rvScheduleAnime"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>